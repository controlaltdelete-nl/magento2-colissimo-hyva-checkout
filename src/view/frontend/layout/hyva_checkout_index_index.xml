<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block name="colissimo_relay_picker"
                   class="LaPoste\Colissimo\Block\Selector"
                   template="ControlAltDelete_ColissimoHyva::checkout/shipping/relay-picker.phtml"
            >
                <arguments>
                    <argument name="magewire" xsi:type="object">
                        ControlAltDelete\ColissimoHyva\Magewire\Checkout\Shipping\RelayPicker
                    </argument>
                </arguments>

                <block name="loading-relay" template="Hyva_Theme::ui/loading.phtml"/>
            </block>
        </referenceContainer>
    </body>
</page>
