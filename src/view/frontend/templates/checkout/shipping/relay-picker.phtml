    <script>
        function initRelayFinder() {
            return {
                open: false,
                errors: 0,
                errorMessages: [],
                loading: false,
                listType: 'list', // list or map
                showMapLocation: false,
                currentLocation: null,
                debounceTimeout: null,
                validationError: null,

                init() {
                    this.loadGoogleMapsApi(() => {
                        this.$refs.relayFinderPopupDialogSearch.addEventListener('gmp-select', async ({placePrediction}) => {
                            const place = placePrediction.toPlace();
                            await place.fetchFields({fields: ['location', 'addressComponents']});

                            this.updatePickupPointsListByLatLng(place.location.lat(), place.location.lng(), place.addressComponents);
                        });
                    })
                },

                isOpen() {
                    return this.open;
                },
                isHidden() {
                    return !this.open;
                },
                isLoading() {
                    return this.loading;
                },
                getTabIndex() {
                    return this.open ? 0 : -1;
                },
                hasErrors() {
                    return this.errors > 0;
                },
                chevronClass() {
                    return {
                        'rotate-180': this.open,
                    }
                },
                renderAsList() {
                    this.listType = 'list';
                },
                shouldRenderAsList() {
                    return this.listType === 'list';
                },
                renderAsListButtonClass() {
                    return this.listType === 'list'
                        ? 'text-black bg-gray-100 border-b-2 border-black'
                        : '';
                },

                renderAsMap() {
                    this.loadGoogleMapsApi(() => this.renderMap());

                    this.listType = 'map';
                },
                shouldRenderAsMap() {
                    return this.listType === 'map';
                },
                renderAsMapButtonClass() {
                    return this.listType === 'map'
                        ? 'text-black bg-gray-100 border-b-2 border-black'
                        : '';
                },

                // Map location
                openMapLocation(point) {
                    this.showMapLocation = true;
                    this.currentLocation = point;
                },
                closeMapLocation() {
                    this.showMapLocation = false;
                    this.currentLocation = null;
                },
                isMapLocationShown() {
                    return this.showMapLocation;
                },
                selectPickupPoint() {
                    this.isLoading();
                    this.$wire.selectPickupPoint(this.currentLocation.identifiant).then(() => {
                        this.closeRelayFinderPopup();
                    });
                },
                currentLocationHtml() {
                    return this.currentLocation ? this.currentLocation.html : '';
                },

                setErrorMessages: function setErrorMessages(messages) {
                    this.errorMessages = messages;
                },
                scrollLock(use = true) {
                    document.body.style.overflow = use ? "hidden" : "";
                },
                loadGoogleMapsApi(callback) {
                    if (document.getElementById('google-maps-script')) {
                        callback();
                        return;
                    }

                    const script = document.createElement('script');
                    script.type = 'text/javascript';
                    script.id = 'google-maps-script';
                    script.src = 'https://maps.googleapis.com/maps/api/js?libraries=places,marker&key=<?= $escaper->escapeJs($magewire->getGoogleMapsApiKey()) ?>&loading=async&callback=initGoogleMapsLibrary';

                    window.initGoogleMapsLibrary = () => callback();
                    document.head.appendChild(script);
                },
                async renderMap(centerPin) {
                    const {Map} = await google.maps.importLibrary("maps");

                    let map = new Map(this.$refs['google-maps-relay'], {
                        zoom: 12,
                        center: {
                            lat: <?= $escaper->escapeJs($magewire->getStartingLatitude()); ?>,
                            lng: <?= $escaper->escapeJs($magewire->getStartingLongitude()); ?>
                        },
                        styles: [
                            {
                                featureType: 'water',
                                elementType: 'geometry',
                                stylers: [{color: '#e9e9e9'}, {lightness: 17}]
                            },
                            {
                                featureType: 'landscape',
                                elementType: 'geometry',
                                stylers: [{color: '#f5f5f5'}, {lightness: 20}]
                            }
                        ]
                    });

                    if (centerPin) {
                        new google.maps.Marker({
                            position: {
                                lat: centerPin.latitude,
                                lng: centerPin.longitude
                            },
                            map: map,
                        });
                    }

                    const bounds = [];
                    const latitudeLongitudeBounds = new google.maps.LatLngBounds();
                    Object.values(this.$wire.renderedPickupPoints).forEach(pickupPoint => {
                        const position = {
                            lat: parseFloat(pickupPoint.coordGeolocalisationLatitude),
                            lng: parseFloat(pickupPoint.coordGeolocalisationLongitude)
                        };
                        bounds.push(position);
                        const marker = new google.maps.Marker({
                            position,
                            map: map,
                        });

                        marker.addListener('click', () => {
                            this.openMapLocation(pickupPoint);
                        });
                    });

                    // Set bounds if multiple locations
                    if (bounds.length > 1) {
                        bounds.forEach(function (bound) {
                            latitudeLongitudeBounds.extend(bound);
                        });
                        map.fitBounds(latitudeLongitudeBounds);
                    }

                    // Center if single location
                    if (bounds.length === 1) {
                        map.setCenter(bounds[0]);
                    }
                },
                openRelayFinderPopup() {
                    this.scrollLock(true);
                    this.$nextTick(() => {
                        this.$refs && this.$refs.relayFinderPopupDialog && hyva.trapFocus(this.$refs.relayFinderPopupDialog)
                    })

                    if (!this.open && this.$wire.pickupPoints.length === 0) {
                        this.loading = true;
                        this.$wire.getPickupPoints().then(() => {
                            this.loading = false
                            this.renderMap();

                            if (this.$wire.errors.length) {
                                this.setErrorMessages(this.$wire.errors);
                                this.errors = this.$wire.errors.length;
                            } else {
                                this.errors = 0;
                                this.errorMessages = [];
                            }
                        });
                    }

                    this.open = true;
                },

                closeRelayFinderPopup() {
                    this.open = false;
                    this.scrollLock(false);
                    this.$refs && this.$refs.relayFinderPopupDialog && hyva.releaseFocus(this.$refs.relayFinderPopupDialog);
                },
                clearValidationError() {
                    this.validationError = null;
                },
                updatePickupPointsListByLatLng(latitude, longitude, addressComponents) {
                    this.loading = true;
                    this.$wire.getPickupPointsForLatlng(latitude, longitude, addressComponents).then(() => {
                        this.loading = false;
                        this.renderMap({latitude, longitude});

                        this.errors = 0;
                        this.errorMessages = [];
                        if (this.$wire.errors.length) {
                            this.setErrorMessages(this.$wire.errors);
                            this.errors = this.$wire.errors.length;
                        }
                    }).catch(() => {
                        this.loading = false;
                        this.validationError = '<?= $escaper->escapeJs(__('Failed to find pickup points near your location')) ?>';
                    });
                },
                getGeolocation() {
                    if (!navigator.geolocation) {
                        this.validationError = '<?= $escaper->escapeJs(__('Geolocation is not supported by this browser')) ?>';
                        return;
                    }

                    this.clearValidationError();
                    this.loading = true;

                    navigator.geolocation.getCurrentPosition(
                        (position) => {
                            const latitude = position.coords.latitude;
                            const longitude = position.coords.longitude;

                            this.updatePickupPointsListByLatLng(latitude, longitude);
                        },
                        (error) => {
                            this.loading = false;

                            let errorMessage;
                            switch (error.code) {
                                case error.PERMISSION_DENIED:
                                    errorMessage = '<?= $escaper->escapeJs(__('Location access denied. Please allow location access or enter your zipcode manually.')) ?>';
                                    break;
                                case error.POSITION_UNAVAILABLE:
                                    errorMessage = '<?= $escaper->escapeJs(__('Location information is unavailable. Please enter your zipcode manually.')) ?>';
                                    break;
                                case error.TIMEOUT:
                                    errorMessage = '<?= $escaper->escapeJs(__('Location request timed out. Please enter your zipcode manually.')) ?>';
                                    break;
                                default:
                                    errorMessage = '<?= $escaper->escapeJs(__('An unknown error occurred while getting your location.')) ?>';
                                    break;
                            }

                            this.validationError = errorMessage;
                        },
                        {
                            enableHighAccuracy: true,
                            timeout: 10000,
                            maximumAge: 300000 // 5 minutes
                        }
                    );
                }
            }
        }

        window.addEventListener(
            'alpine:init',
            () => Alpine.data('initRelayFinder', initRelayFinder),
            {once: true}
        )
    </script>
    <?php $hyvaCsp->registerInlineScript() ?>

    <script>
        function colissimoPickupPoint() {
            return {
                open: false,
                pickupPoint: null,

                init() {
                    this.pickupPoint = JSON.parse(this.$root.dataset.pickuppoint)
                },

                isOpen() {
                    return this.open;
                },
                toggleOpen() {
                    this.open = !this.open;
                },

                isDisabled() {
                    return this.$wire.selectedPickupPointId === this.pickupPoint.identifiant;
                },

                selectPickupPoint() {
                    this.$wire.selectPickupPoint(this.pickupPoint.identifiant);
                    window.dispatchEvent(new CustomEvent('relay-point-picked', {detail: {pickupPoint: this.pickupPoint}}));
                },

                selectedPickupPointText() {
                    return this.$wire.selectedPickupPointId === this.pickupPoint.identifiant ? '<?= $escaper->escapeJs(__('Selected')) ?>' : '<?= $escaper->escapeJs(__('Select this pickup point')) ?>'
                }
            }
        }

        window.addEventListener(
            'alpine:init',
            () => Alpine.data('colissimoPickupPoint', colissimoPickupPoint),
            {once: true}
        )
    </script>
    <?php $hyvaCsp->registerInlineScript() ?>

    <script>
